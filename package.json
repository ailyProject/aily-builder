{
  "name": "@aily-project/aily-builder-next",
  "version": "1.2.8",
  "description": "Fast Arduino compilation CLI tool with optimized preprocessing and parallel compilation",
  "main": "dist/main.js",
  "bin": {
    "aily-builder": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "dist/src",
    "README.md",
    "README-ZH.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "bundle": "npm run build && node bundle.js --minify",
    "start": "ts-node main.ts",
    "clean": "rimraf dist",
    "prepack": "npm run build"
  },
  "keywords": [
    "arduino",
    "cli",
    "compilation",
    "build",
    "embedded"
  ],
  "author": "coloz",
  "license": "GPL-3.0-only",
  "dependencies": {
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.16",
    "esbuild": "^0.25.9",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18"
  }
}
