{
  "name": "@aily-project/aily-builder-next",
  "version": "1.2.5",
  "description": "Fast Arduino compilation CLI tool with optimized preprocessing and parallel compilation",
  "main": "dist/main.js",
  "bin": {
    "aily-builder": "dist/main.js"
  },
  "files": [
    "dist/main.js",
    "dist/src",
    "README.md",
    "README-ZH.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf dist && tsc",
    "bundle:native:minify": "npm run build && node bundle-native.js --minify",
    "bundle:native:minify:generate-cache": "npm run build && node bundle-native.js --minify --generate-archive-cloud-cache-default",
    "start": "ts-node main.ts",
    "clean": "rimraf dist",
    "prepack": "npm run build"
  },
  "keywords": [
    "arduino",
    "cli",
    "compilation",
    "build",
    "embedded"
  ],
  "author": "coloz",
  "license": "GPL-3.0-only",
  "dependencies": {
    "@ast-grep/lang-cpp": "^0.0.4",
    "@ast-grep/napi": "^0.40.3",
    "commander": "^11.1.0",
    "fs-extra": "^11.2.0",
    "glob": "^10.4.5",
    "tree-sitter": "^0.20.4",
    "tree-sitter-cpp": "^0.20.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.11.16",
    "esbuild": "^0.25.9",
    "jest": "^29.7.0",
    "rimraf": "^5.0.5",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=16"
  }
}
